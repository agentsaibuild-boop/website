---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageSchema = {
  '@type': 'ContactPage',
  '@id': 'https://example.com/kontakt#page',
  url: 'https://example.com/kontakt',
  name: 'Контакт – AIBUILD AGENTS',
  isPartOf: { '@id': 'https://example.com/#website' },
  description: 'Свържете се с AIBUILD AGENTS за заявка за демо или въпроси относно платформата.',
  inLanguage: 'bg-BG',
};
---

<BaseLayout
  title="Контакт – AIBUILD AGENTS | Заявка за демо"
  description="Свържете се с нас за заявка за демо, въпроси за платформата или обсъждане на конкретен случай. Отговаряме до 1 работен ден."
  schema={pageSchema}
>
  <section style="padding-block: 5rem 4rem; border-bottom: 1px solid var(--color-border);" class="contact-hero">
    <div class="container">
      <p class="eyebrow" style="margin-bottom: 1.25rem;">Контакт</p>
      <h1 style="max-width: 18ch;">Свържете се с нас</h1>
      <p style="margin-top: 1.25rem; font-size: 1.0625rem; color: var(--color-muted); line-height: 1.65; max-width: 48ch;">
        Заявете демо с ваша реална документация или задайте въпроси за платформата. Отговаряме до 1 работен ден.
      </p>
    </div>
  </section>

  <section class="section" style="border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr; gap: 4rem; align-items: start;" class="contact-grid">

        <div>
          <h2 style="font-size: 1.375rem; margin-bottom: 2rem;">Изпратете съобщение</h2>
          <form
            name="contact"
            method="POST"
            action="mailto:hello@example.com"
            enctype="text/plain"
            netlify
            style="display: flex; flex-direction: column; gap: 1.25rem;"
            aria-label="Форма за контакт"
          >
            <input type="hidden" name="form-name" value="contact" />

            <div style="display: grid; gap: 0.375rem;">
              <label for="name" style="font-size: 0.875rem; font-weight: 500;">
                Имена <span aria-hidden="true" style="color: var(--color-accent);">*</span>
              </label>
              <input type="text" id="name" name="name" required autocomplete="name" placeholder="Иван Иванов" class="form-input" />
            </div>

            <div style="display: grid; gap: 0.375rem;">
              <label for="company" style="font-size: 0.875rem; font-weight: 500;">Компания</label>
              <input type="text" id="company" name="company" autocomplete="organization" placeholder="ЕООД / АД / Консултантска фирма" class="form-input" />
            </div>

            <div style="display: grid; gap: 0.375rem;">
              <label for="email" style="font-size: 0.875rem; font-weight: 500;">
                Имейл <span aria-hidden="true" style="color: var(--color-accent);">*</span>
              </label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder="ivan@company.bg" class="form-input" />
            </div>

            <div style="display: grid; gap: 0.375rem;">
              <label for="subject" style="font-size: 0.875rem; font-weight: 500;">
                Тема <span aria-hidden="true" style="color: var(--color-accent);">*</span>
              </label>
              <select id="subject" name="subject" required class="form-input" style="cursor: pointer; appearance: none;">
                <option value="" disabled selected>Изберете тема...</option>
                <option value="demo">Заявка за демо</option>
                <option value="pricing">Въпрос за цени и планове</option>
                <option value="app-request">Запитване за конкретно приложение</option>
                <option value="technical">Технически въпрос</option>
                <option value="partnership">Партньорство</option>
                <option value="other">Друго</option>
              </select>
            </div>

            <div style="display: grid; gap: 0.375rem;">
              <label for="message" style="font-size: 0.875rem; font-weight: 500;">
                Съобщение <span aria-hidden="true" style="color: var(--color-accent);">*</span>
              </label>
              <textarea
                id="message" name="message" required rows="5"
                placeholder="Опишете вашия случай — с какъв тип документи работите, какъв е основният проблем или какво приложение ви интересува..."
                class="form-input"
                style="resize: vertical; min-height: 7rem;"
              ></textarea>
            </div>

            <p style="font-size: 0.8125rem; color: var(--color-subtle); line-height: 1.55;">
              С изпращането се съгласявате с нашата
              <a href="/politika-za-poveritelnost" style="color: var(--color-accent); text-decoration: underline;">Политика за поверителност</a>.
            </p>

            <button type="submit" class="btn-primary" style="align-self: start; min-width: 10rem;">
              Изпрати съобщение
            </button>
          </form>
        </div>

        <aside>
          <h2 style="font-size: 1.375rem; margin-bottom: 2rem;">Директен контакт</h2>
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">

            <div style="display: flex; gap: 1rem; align-items: start;">
              <div style="width:2.25rem;height:2.25rem;border:1px solid var(--color-border);border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--color-accent);" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2.5 4A1.5 1.5 0 014 2.5h8A1.5 1.5 0 0113.5 4v8A1.5 1.5 0 0112 13.5H4A1.5 1.5 0 012.5 12V4z" stroke="currentColor" stroke-width="1.25"/><path d="M2.5 6l5.5 3.5L13.5 6" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="label-mono" style="color: var(--color-subtle); margin-bottom: 0.25rem;">Имейл</p>
                <a href="mailto:hello@example.com" style="font-weight:500;color:var(--color-accent);" class="contact-link">hello@example.com</a>
              </div>
            </div>

            <div style="display: flex; gap: 1rem; align-items: start;">
              <div style="width:2.25rem;height:2.25rem;border:1px solid var(--color-border);border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--color-accent);" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 10.5c0 .3-.07.6-.2.9-.14.3-.3.57-.54.8-.38.4-.8.6-1.26.61-.33 0-.68-.08-1.06-.25a10.5 10.5 0 01-1.07-.63 16.7 16.7 0 01-1.03-.9 16.6 16.6 0 01-.89-1.02 10.4 10.4 0 01-.62-1.06C6.08 8.57 6 8.22 6 7.9c0-.32.07-.63.2-.91.13-.28.33-.54.58-.76.3-.27.62-.4.97-.4.14 0 .27.03.39.09.13.06.24.15.33.28l1.12 1.58c.09.12.16.24.2.35.05.1.08.2.08.3 0 .12-.03.24-.1.36-.06.11-.15.23-.27.35l-.36.37c-.05.06-.08.12-.08.2 0 .04 0 .08.02.12.03.04.05.08.07.12.17.31.36.6.58.88.23.28.47.56.73.82.27.27.55.51.84.73.29.22.58.41.88.58.03.02.07.04.12.06.04.02.09.02.14.02.09 0 .15-.03.2-.09l.37-.37c.12-.12.24-.21.35-.27.11-.06.23-.1.36-.1.1 0 .2.02.3.07.1.05.22.12.34.21l1.6 1.14c.13.09.22.2.28.33.05.13.08.27.08.42z" stroke="currentColor" stroke-width="1.25"/></svg>
              </div>
              <div>
                <p class="label-mono" style="color: var(--color-subtle); margin-bottom: 0.25rem;">Телефон</p>
                <a href="tel:+359000000000" style="font-weight:500;" class="contact-link">+359 000 000 000</a>
              </div>
            </div>

            <div style="margin-top:1rem;padding:1.25rem;background:var(--color-accent-tint);border-radius:6px;border-left:2px solid var(--color-accent);">
              <p style="font-size:0.875rem;color:var(--color-text);line-height:1.6;">
                <strong>Отговаряме до 1 работен ден.</strong><br>
                За демо сесии предлагаме слотове в работни дни 9:00–18:00 ч.
              </p>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (min-width: 768px) {
    .contact-hero { padding-block: 7rem 5rem !important; }
    .contact-grid { grid-template-columns: 3fr 2fr !important; }
  }

  .form-input {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-size: 0.9375rem;
    font-family: inherit;
    background: var(--color-surface);
    color: var(--color-text);
    transition: border-color 0.15s ease;
    width: 100%;
  }

  .form-input:focus {
    border-color: var(--color-accent);
    outline: none;
    box-shadow: 0 0 0 3px var(--color-accent-tint);
  }

  .contact-link:hover { text-decoration: underline; }
</style>
