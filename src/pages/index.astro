---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Steps from '../components/Steps.astro';
import ProofMetrics from '../components/ProofMetrics.astro';
import FAQ from '../components/FAQ.astro';
import CTABlock from '../components/CTABlock.astro';

const base = import.meta.env.BASE_URL;

const pageSchema = {
  '@type': 'WebPage',
  '@id': 'https://example.com/#webpage',
  url: 'https://example.com/',
  name: 'AIBUILD AGENTS – Цялостни AI решения за строителния бизнес',
  isPartOf: { '@id': 'https://example.com/#website' },
  about: { '@id': 'https://example.com/#org' },
  description:
    'Екосистема от AI приложения за строителни дружества и инженерни консултанти.',
  inLanguage: 'bg-BG',
};

const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 4h12v2H4V4zm0 5h12v2H4V9zm0 5h8v2H4v-2z" fill="currentColor"/></svg>`,
    title: 'Четене на документация',
    body: 'AI анализира стотици PDF страници за минути — технически спецификации, количествени сметки, нормативни изисквания.',
    link: { href: `${base}prilozheniya`, label: 'Вижте приложенията' },
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 10a7 7 0 1014 0A7 7 0 003 10z" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: 'Автоматично съответствие',
    body: 'Проверка спрямо нормативни изисквания, стандарти и условия — без ръчна работа, с пълна проследимост.',
    link: { href: `${base}resheniya`, label: 'Как работи' },
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M6 2h8a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V4a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5"/><path d="M8 7h4M8 11h4M8 15h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'Генериране на предложения',
    body: 'Структурирани технически предложения с обосновки и референции — готови за финализиране от вашия екип.',
    link: { href: `${base}prilozheniya`, label: 'Use cases' },
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="3" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="11" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="11" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 2"/></svg>`,
    title: 'Растяща екосистема',
    body: 'Техническите предложения са първото приложение. Следват: анализ на КСС, управление на документация, контрол на изпълнение и още.',
    link: { href: `${base}prilozheniya`, label: 'Всички приложения' },
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M3 10h10M3 15h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="16" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M16 13v1.5l1 1" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>`,
    title: 'Пълна проследимост',
    body: 'Всяко твърдение е свързано с изходния документ. Одитна следа на всяко действие и изменение.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L2 6v8l8 4 8-4V6l-8-4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M2 6l8 4m0 0l8-4m-8 4v8" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
    title: 'Интеграция с вашия процес',
    body: 'Платформата се адаптира към съществуващия ви работен процес. API достъп и export в стандартни формати.',
    link: { href: `${base}resheniya`, label: 'Технически детайли' },
  },
];

const steps = [
  {
    title: 'Качете документацията',
    body: 'PDF, DOCX или сканирани документи — техническо задание, количествена сметка, проектни чертежи. Без ограничение на брой файлове.',
  },
  {
    title: 'AI анализира и структурира',
    body: 'Системата извлича изисквания, параметри и условия. Свързва информация от различни документи в единна структура.',
  },
  {
    title: 'Преглеждате и допълвате',
    body: 'Вашият екип преглежда, добавя специфична информация и одобрява предложените формулировки.',
  },
  {
    title: 'Изнасяте финалния документ',
    body: 'Готовият документ в DOCX, PDF или директно за качване в платформата на възложителя.',
  },
];

const metrics = [
  { value: 'до 80%', label: 'по-бърза подготовка на предложение' },
  { value: '< 3 мин', label: 'за анализ на 200-странично PDF' },
  { value: '100%', label: 'проследимост на изисквания' },
  { value: '4×', label: 'повече процедури с един екип' },
];

const faqItems = [
  {
    question: 'Само ли за технически предложения е платформата?',
    answer:
      'Не. Техническите предложения са първото внедрено приложение. AIBUILD AGENTS е платформа-основа, върху която изграждаме цялостна екосистема от AI инструменти за строителния бизнес — анализ на КСС, управление на проектна документация, контрол на изпълнение, сравнение на оферти и още. Всяко ново приложение се интегрира в същата среда.',
  },
  {
    question: 'Какви документи може да обработва платформата?',
    answer:
      'PDF (включително сканирани с OCR), DOCX и XLSX. Поддържани типове: технически спецификации, количествени сметки, решения за обществени поръчки, технически стандарти, протоколи от строителен надзор и др.',
  },
  {
    question: 'Как се гарантира поверителността на проектната документация?',
    answer:
      'Документите се обработват в изолирана среда, специфична за вашата организация. Данните не се споделят между клиенти, не се използват за обучение на AI модели и могат да се съхраняват в EU-базирана инфраструктура.',
  },
  {
    question: 'Нужна ли е техническа подготовка за работа с платформата?',
    answer:
      'Не. Интерфейсът е уеб-базиран и изисква само браузър. Повечето потребители стартират продуктивна работа след половин ден онбординг.',
  },
  {
    question: 'Колко точни са AI-генерираните резултати?',
    answer:
      'Точността зависи от качеството на входните документи. Системата маркира всяко твърдение с ниво на увереност и посочва изходния документ. Проектирана е за работа заедно с вашите специалисти — не вместо тях.',
  },
  {
    question: 'Как протича внедряването?',
    answer:
      '1) Демо сесия с ваша реална документация; 2) Технически онбординг (1–2 дни); 3) Пилотна процедура с поддръжка; 4) Пълно внедряване. Обичайният срок от демо до продуктивна работа е 2–4 седмици.',
  },
  {
    question: 'Поддържа ли платформата работа с екипи?',
    answer:
      'Да. Множество потребители с роли (редактор, рецензент, одобряващ), одит лог и коментарна функция за вътрешен преглед.',
  },
];
---

<BaseLayout
  title="AIBUILD AGENTS – Цялостни AI решения за строителния бизнес"
  description="Екосистема от AI приложения за строителни дружества и инженерни консултанти. От технически предложения до управление на документация — автоматизирано и проследимо."
  schema={pageSchema}
>
  <Hero
    eyebrow="AI · Строителство · Инженеринг"
    headline="AI, който работи за вашия строителен бизнес"
    subheadline="AIBUILD AGENTS е платформа от AI приложения за строителни дружества и инженерни консултанти. Автоматизира рутинните процеси — от технически предложения до управление на документация."
    ctaPrimary={{ href: `${base}kontakt`, label: 'Заявка за демо' }}
    ctaSecondary={{ href: `${base}resheniya`, label: 'Разгледай решенията' }}
  />

  <FeatureGrid
    eyebrow="Платформата"
    headline="Цялостна AI екосистема за строителния сектор"
    subheadline="Едно работно пространство с нарастващ набор от AI приложения — всяко решава конкретен проблем в строителния процес."
    features={features}
  />

  <Steps
    eyebrow="Как работи"
    headline="От документ до резултат в четири стъпки"
    steps={steps}
  />

  <ProofMetrics
    eyebrow="Резултати (пример)"
    metrics={metrics}
  />

  <FAQ
    eyebrow="FAQ"
    headline="Често задавани въпроси"
    items={faqItems}
  />

  <CTABlock />
</BaseLayout>
