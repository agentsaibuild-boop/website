---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="404 – Страницата не е намерена | AIBUILD AGENTS"
  description="Търсената страница не съществува. Върнете се към началната страница на AIBUILD AGENTS."
  noIndex={true}
>
  <section
    style="
      min-height: 70vh;
      display: flex;
      align-items: center;
      border-bottom: 1px solid var(--color-border);
    "
  >
    <div class="container">
      <div style="max-width: 540px;">

        <p style="
          font-family: var(--font-family-mono);
          font-size: clamp(4rem, 12vw, 8rem);
          font-weight: 400;
          letter-spacing: -0.04em;
          line-height: 1;
          color: var(--color-border);
          margin-bottom: 1.5rem;
          user-select: none;
        " aria-hidden="true">
          404
        </p>

        <p class="eyebrow" style="margin-bottom: 1rem; color: var(--color-accent);">
          Страница не е намерена
        </p>

        <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 1rem;">
          Тук няма нищо
        </h1>

        <p style="font-size: 1rem; color: var(--color-muted); line-height: 1.7; margin-bottom: 2rem; max-width: 44ch;">
          Страницата, която търсите, не съществува или е преместена. Проверете адреса или се върнете назад.
        </p>

        <!-- Primary CTA -->
        <a href={base} class="btn-primary" style="margin-bottom: 3rem; display: inline-flex;">
          ← Върни се към началната страница
        </a>

        <!-- Quick links -->
        <div style="padding-top: 2rem; border-top: 1px solid var(--color-border);">
          <p class="label-mono" style="margin-bottom: 1rem;">Може би търсите:</p>
          <ul style="display: flex; flex-direction: column; gap: 0.5rem; list-style: none;">
            {[
              { href: `${base}resheniya`,    label: 'Платформата и решенията' },
              { href: `${base}prilozheniya`, label: 'Приложения и use cases' },
              { href: `${base}za-nas`,       label: 'За нас' },
              { href: `${base}kontakt`,      label: 'Контакт и демо' },
            ].map(l => (
              <li>
                <a href={l.href} style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.9375rem;font-weight:500;color:var(--color-accent);" class="notfound-link">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound-link:hover { text-decoration: underline; }
</style>
