---
interface Feature {
  icon: string;   // SVG path data or inline SVG string
  title: string;
  body: string;
  link?: { href: string; label: string };
}

interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  features: Feature[];
}

const { eyebrow, headline, subheadline, features } = Astro.props;
---

<section class="section" style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border);">
  <div class="container">

    <!-- Section header -->
    <div style="margin-bottom: 3.5rem; max-width: 640px;">
      {eyebrow && <p class="eyebrow" style="margin-bottom: 0.875rem;">{eyebrow}</p>}
      <h2 style="margin-bottom: 1rem;">{headline}</h2>
      {subheadline && (
        <p style="font-size: 1.0625rem; color: var(--color-muted); line-height: 1.65; max-width: 52ch;">
          {subheadline}
        </p>
      )}
    </div>

    <!-- Feature cards -->
    <div style="
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
    " class="feature-grid">
      {features.map((f, i) => (
        <article
          class="card"
          data-reveal
          data-delay={String(Math.min(i % 3 + 1, 6))}
          style="position: relative; overflow: hidden;"
          aria-labelledby={`feat-${i}`}
        >
          <!-- Index hairline -->
          <span class="label-mono" style="
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            color: var(--color-border);
            font-size: 0.625rem;
          ">
            {String(i + 1).padStart(2, '0')}
          </span>

          <!-- Icon -->
          <div style="
            width: 2.5rem;
            height: 2.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--color-accent-tint);
            border-radius: 6px;
            margin-bottom: 1.25rem;
            color: var(--color-accent);
          " aria-hidden="true">
            <Fragment set:html={f.icon} />
          </div>

          <h3 id={`feat-${i}`} style="margin-bottom: 0.625rem;">{f.title}</h3>
          <p style="font-size: 0.9375rem; color: var(--color-muted); line-height: 1.65;">
            {f.body}
          </p>

          {f.link && (
            <a
              href={f.link.href}
              style="
                display: inline-flex;
                align-items: center;
                gap: 0.375rem;
                margin-top: 1.25rem;
                font-size: 0.875rem;
                font-weight: 600;
                color: var(--color-accent);
              "
              class="feature-more-link"
            >
              {f.link.label}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  @media (min-width: 640px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (min-width: 1024px) {
    .feature-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }

  .feature-more-link:hover {
    text-decoration: underline;
  }
</style>
