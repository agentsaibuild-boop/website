---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  eyebrow?: string;
  headline?: string;
  items: FAQItem[];
}

const base = import.meta.env.BASE_URL;

const {
  eyebrow = 'Въпроси и отговори',
  headline = 'Честоотговаряни въпроси',
  items,
} = Astro.props;

// Schema.org FAQPage JSON-LD
const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section class="section" style="border-bottom: 1px solid var(--color-border);">
  <div class="container">

    <div style="
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
    " class="faq-wrapper">

      <!-- Header -->
      <div class="faq-header">
        {eyebrow && <p class="eyebrow" style="margin-bottom: 0.875rem;">{eyebrow}</p>}
        <h2 style="max-width: 18ch;">{headline}</h2>
        <p style="margin-top: 1rem; font-size: 0.9375rem; color: var(--color-muted); max-width: 36ch; line-height: 1.65;">
          Не намирате отговора? <a href={`${base}kontakt`} style="color: var(--color-accent); font-weight: 500;" class="faq-contact-link">Свържете се с нас.</a>
        </p>
      </div>

      <!-- Accordion via native <details> – zero JS needed -->
      <div>
        <dl>
          {items.map((item, i) => (
            <details
              class="faq-item"
              style={`
                border-top: 1px solid var(--color-border);
                ${i === items.length - 1 ? 'border-bottom: 1px solid var(--color-border);' : ''}
              `}
            >
              <summary style="
                display: flex;
                justify-content: space-between;
                align-items: start;
                gap: 1rem;
                padding-block: 1.25rem;
                cursor: pointer;
                list-style: none;
                user-select: none;
              " class="faq-summary">
                <dt style="
                  font-size: 1rem;
                  font-weight: 600;
                  letter-spacing: -0.01em;
                  line-height: 1.35;
                  flex: 1;
                ">
                  {item.question}
                </dt>
                <!-- Plus/minus indicator -->
                <span class="faq-icon" aria-hidden="true" style="
                  flex-shrink: 0;
                  width: 1.25rem;
                  height: 1.25rem;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  margin-top: 0.125rem;
                  color: var(--color-accent);
                ">
                  <svg class="faq-icon-plus" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  <svg class="faq-icon-minus" width="16" height="16" viewBox="0 0 16 16" fill="none" style="display: none;">
                    <path d="M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </span>
              </summary>
              <dd style="padding-bottom: 1.375rem; padding-right: 2.5rem;">
                <p style="font-size: 0.9375rem; color: var(--color-muted); line-height: 1.7;">
                  {item.answer}
                </p>
              </dd>
            </details>
          ))}
        </dl>
      </div>

    </div>
  </div>
</section>

<!-- Inject FAQPage schema -->
<script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', ...faqSchema })} />

<style>
  @media (min-width: 768px) {
    .faq-wrapper {
      grid-template-columns: 1fr 2fr !important;
      gap: 5rem !important;
    }

    .faq-header {
      position: sticky;
      top: 6rem;
    }
  }

  .faq-item[open] .faq-icon-plus  { display: none !important; }
  .faq-item[open] .faq-icon-minus { display: flex !important; }

  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { display: none; }

  .faq-summary:hover dt {
    color: var(--color-accent);
  }

  .faq-contact-link:hover {
    text-decoration: underline;
  }
</style>
