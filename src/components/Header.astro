---
const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: `${base}resheniya`,    label: 'Решения' },
  { href: `${base}prilozheniya`, label: 'Приложения' },
  { href: `${base}za-nas`,       label: 'За нас' },
  { href: `${base}kontakt`,      label: 'Контакт' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  role="banner"
  style="
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(244, 243, 241, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  "
>
  <div class="container">
    <div style="display: flex; align-items: center; justify-content: space-between; height: 4rem; gap: 2rem;">

      <!-- Logo / Brand -->
      <a
        href={base}
        aria-label="AIBUILD AGENTS – начало"
        style="display: flex; flex-direction: column; gap: 0.125rem; flex-shrink: 0;"
      >
        <span style="font-weight: 700; font-size: 0.9375rem; letter-spacing: -0.02em; color: var(--color-text); line-height: 1;">
          AIBUILD AGENTS
        </span>
        <span class="label-mono" style="color: var(--color-accent);">AI · Строителство</span>
      </a>

      <!-- Desktop Navigation -->
      <nav aria-label="Главна навигация" style="display: none;" id="desktop-nav">
        <ul style="display: flex; align-items: center; gap: 0.25rem; list-style: none;">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
                style={`
                  padding: 0.375rem 0.75rem;
                  border-radius: 4px;
                  font-size: 0.875rem;
                  font-weight: 500;
                  letter-spacing: -0.01em;
                  color: ${currentPath.startsWith(link.href)
                    ? 'var(--color-accent)'
                    : 'var(--color-muted)'};
                  transition: color 0.15s ease, background-color 0.15s ease;
                `}
                class="nav-link"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Desktop CTA -->
      <div style="display: none;" id="desktop-cta">
        <a href={`${base}kontakt`} class="btn-primary" style="font-size: 0.875rem; padding: 0.625rem 1.25rem;">
          Заявка за демо
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="nav-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Отвори навигацията"
        style="
          display: flex;
          flex-direction: column;
          justify-content: center;
          gap: 5px;
          width: 2.5rem;
          height: 2.5rem;
          padding: 0.5rem;
          border-radius: 4px;
          color: var(--color-text);
          flex-shrink: 0;
        "
      >
        <span class="ham-line" style="display: block; width: 100%; height: 1.5px; background: currentColor; transition: transform 0.2s ease, opacity 0.2s ease;"></span>
        <span class="ham-line" style="display: block; width: 100%; height: 1.5px; background: currentColor; transition: transform 0.2s ease, opacity 0.2s ease;"></span>
        <span class="ham-line" style="display: block; width: 100%; height: 1.5px; background: currentColor; transition: transform 0.2s ease, opacity 0.2s ease;"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    role="navigation"
    aria-label="Мобилна навигация"
    style="
      display: none;
      border-top: 1px solid var(--color-border);
      background-color: var(--color-bg);
      padding: 1rem 0 1.5rem;
    "
  >
    <div class="container">
      <ul style="display: flex; flex-direction: column; gap: 0.25rem; list-style: none; margin-bottom: 1.25rem;">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              style={`
                display: block;
                padding: 0.625rem 0.75rem;
                border-radius: 4px;
                font-size: 1rem;
                font-weight: 500;
                color: ${currentPath.startsWith(link.href)
                  ? 'var(--color-accent)'
                  : 'var(--color-text)'};
              `}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <a href={`${base}kontakt`} class="btn-primary" style="width: 100%; justify-content: center;">
        Заявка за демо
      </a>
    </div>
  </div>
</header>

<style>
  @media (min-width: 768px) {
    #desktop-nav  { display: block !important; }
    #desktop-cta  { display: block !important; }
    #nav-toggle   { display: none !important; }
  }

  .nav-link:hover {
    color: var(--color-text) !important;
    background-color: rgba(0, 0, 0, 0.04);
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu   = document.getElementById('mobile-menu');
  const lines  = toggle?.querySelectorAll('.ham-line') as NodeListOf<HTMLElement>;

  toggle?.addEventListener('click', () => {
    const isOpen = menu!.style.display === 'block';
    menu!.style.display = isOpen ? 'none' : 'block';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Отвори навигацията' : 'Затвори навигацията');
    if (lines) {
      if (!isOpen) {
        lines[0].style.transform = 'translateY(6.5px) rotate(45deg)';
        lines[1].style.opacity   = '0';
        lines[2].style.transform = 'translateY(-6.5px) rotate(-45deg)';
      } else {
        lines[0].style.transform = '';
        lines[1].style.opacity   = '';
        lines[2].style.transform = '';
      }
    }
  });
</script>
